events {
    worker_connections 1024;
}

http {
    # Docker internal DNS resolver
    resolver 127.0.0.11 valid=30s;

    server {
        listen 80;

        location / {
            # Using a variable forces Nginx to resolve the hostname at runtime 
            # instead of at startup, preventing the "host not found" crash.
            set $upstream_frontend http://frontend:5173;
            proxy_pass $upstream_frontend;
            
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection 'upgrade';
            proxy_set_header Host $host;
            proxy_cache_bypass $http_upgrade;
            add_header X-Powered-By "WorldCup-Nginx-Proxy";
        }

        location /api {
            # Using a variable for backend as well for consistency
            set $upstream_backend http://backend:8000;
            rewrite ^/api/(.*)$ /$1 break;
            proxy_pass $upstream_backend;
            
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }
    }
}
